# === LLM Provider ===
# Options: "openai" or "ollama"
LLM_PROVIDER=openai

# === OpenAI (if LLM_PROVIDER=openai) ===
OPENAI_API_KEY=your-api-key-here

# === Ollama (if LLM_PROVIDER=ollama) ===
# Install: https://ollama.ai
# Pull a model: ollama pull llama3.1
# Ollama runs at http://localhost:11434 by default
# Note: Ollama model must support JSON mode (e.g. llama3.1, mistral)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIM=768

# === Model Config ===
# Text model for reasoning (OpenAI: gpt-4o-mini, Ollama: llama3.1)
LLM_MODEL=gpt-4o-mini
# Vision model for diagram analysis during ingest (OpenAI only)
VISION_MODEL=gpt-4o
# Smart model for batch discovery and evaluation judge
SMART_MODEL=gpt-4o
# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# === Evaluation (optional) ===
JUDGE_MODEL=gpt-4o
MAX_WORKERS=5
